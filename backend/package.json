{
  "name": "acereads-backend",
  "version": "1.0.0",
  "description": "AceReads Bookstore Management System — CS492 Group Project 2",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "seed:clear": "node seed.js --clear",
    "seed:reset": "node seed.js --reset",
    "test": "jest --testEnvironment=node --forceExit"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "verbose": true
  }
}
