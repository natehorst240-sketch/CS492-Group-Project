# Dependencies — never commit these, npm install recreates them
node_modules/

# Database — each developer gets their own local copy
*.db
*.sqlite
*.sqlite3

# Environment variables — never commit passwords or secrets
.env
.env.local
.env.production

# Seed database (generated by npm run seed)
database.db

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# VS Code settings (optional — remove this if your team wants to share settings)
.vscode/

# Logs
*.log
npm-debug.log*

# ZIP files — submit separately, don't commit
*.zip
